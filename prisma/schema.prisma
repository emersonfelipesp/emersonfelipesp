datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model PageView {
  path      String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
